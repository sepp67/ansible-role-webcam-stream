#!/usr/bin/env bash
set -euo pipefail

gallery_dir="{{ webcam_gallery_dir }}"
output_file="${gallery_dir}/index.html"

cat > "${output_file}" <<'EOF'
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>Webcam Snapshots</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #111;
      color: #eee;
      margin: 0;
      padding: 2rem;
    }
    a { color: #7cc7ff; }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 1rem;
    }
    .card {
      background: #1b1b1b;
      border-radius: 8px;
      overflow: hidden;
      padding: 0.75rem;
    }
    img {
      width: 100%;
      border-radius: 6px;
      display: block;
    }
    .meta {
      margin-top: 0.5rem;
      color: #ccc;
      font-size: 0.9rem;
    }
  </style>
</head>
<body>
  <h1>Webcam Snapshots</h1>
  <p><a href="/">Back to live stream</a></p>
  <div class="grid">
EOF

find "${gallery_dir}" -maxdepth 1 -type f -name '*.jpg' | sort -r | while read -r img; do
  base="$(basename "${img}")"
  ts="${base%.jpg}"
  cat >> "${output_file}" <<EOF
    <div class="card">
      <a href="/gallery/${base}"><img src="/gallery/${base}" alt="${base}"></a>
      <div class="meta">${ts}</div>
    </div>
EOF
done

cat >> "${output_file}" <<'EOF'
  </div>
</body>
</html>
EOF
